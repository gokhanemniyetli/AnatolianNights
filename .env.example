# Anadolu Türküleri Ezgileri — Environment Configuration
# Copy this file to .env and fill in your values

# ── Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── YouTube Data API ─────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=config/youtube_client_secrets.json
YOUTUBE_CHANNEL_ID=

# ── Suno ─────────────────────────────────────────────────
# Options: manual | browser
SUNO_CLIENT=manual
# Required only for browser mode:
SUNO_EMAIL=
SUNO_PASSWORD=

# ── Pipeline ─────────────────────────────────────────────
DRY_RUN=false
# Default number of topics per cycle
DEFAULT_K=1
# Quality score threshold (0-10), songs below this are rejected
QUALITY_THRESHOLD=8.0
# Max lyric generation retries before permanent rejection
MAX_LYRIC_RETRIES=3

# ── Storage ──────────────────────────────────────────────
OUTPUTS_DIR=outputs
DATABASE_URL=sqlite:///data/anadolu.db

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
